# Supabase 配置
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cron 任务密钥
CRON_SECRET=your-cron-secret-key

# Google Trends 增强（可选，免费100次/月）
# 注册地址: https://serpapi.com/
SERPAPI_KEY=your-serpapi-key

# Reddit OAuth（可选，被封锁时留空，系统自动降级）
# 申请：https://www.reddit.com/prefs/apps → script 类型
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret

# ── 数据源权重配置（无需重部署，修改后 Vercel 环境变量即时生效）──
# Reddit 封锁期间配置（当前默认值）：
SCORE_WEIGHT_GOOGLE=0.40
SCORE_WEIGHT_RSS=0.60
SCORE_WEIGHT_REDDIT=0.00
# Reddit 恢复后改为：
# SCORE_WEIGHT_GOOGLE=0.35
# SCORE_WEIGHT_RSS=0.35
# SCORE_WEIGHT_REDDIT=0.30
